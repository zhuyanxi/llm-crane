{
  "name": "@llm-crane/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "vscode": "^1.100.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:llmCrane.runTask"
  ],
  "contributes": {
    "commands": [
      {
        "command": "llmCrane.runTask",
        "title": "LLM Crane: Run Task"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@llm-crane/core": "workspace:*",
    "@llm-crane/schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0"
  }
}