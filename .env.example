LLM_CRANE_SIMPLE_MODEL=gpt-4o-mini
LLM_CRANE_COMPLEX_MODEL=claude-3-5-sonnet-latest
# Example local runtime profile:
# LLM_CRANE_RUNTIME_PROFILES=[{"runtimeId":"ollama-local","providerId":"ollama","deploymentMode":"local","apiFamily":"ollama","baseUrl":"http://127.0.0.1:11434","models":["qwen2.5-coder:7b"],"authMode":"none","timeoutMs":30000}]
# Example LM Studio / OpenAI-compatible local profile:
# LLM_CRANE_RUNTIME_PROFILES=[{"runtimeId":"lmstudio-local","providerId":"openai","deploymentMode":"local","apiFamily":"openai-compatible","baseUrl":"http://127.0.0.1:1234/v1","models":["local-qwen2.5-coder"],"authMode":"header","authToken":"lmstudio-secret","authHeaderName":"X-LM-Studio-Key","headers":{"X-Client":"llm-crane"},"timeoutMs":45000}]
LLM_CRANE_RUNTIME_PROFILES=[]
LLM_CRANE_TRANSPORT=stdio
LLM_CRANE_LOG_LEVEL=info
LLM_CRANE_CACHE_TTL_MS=86400000
LLM_CRANE_PROVIDER_MAX_RETRIES=2
LLM_CRANE_PROVIDER_BACKOFF_STRATEGY=exponential
LLM_CRANE_PROVIDER_RETRY_BASE_DELAY_MS=500
LLM_CRANE_PROVIDER_RETRY_MAX_DELAY_MS=4000
LLM_CRANE_ENABLE_PROVIDER_FALLBACK=true
LLM_CRANE_SIMPLE_FALLBACK_MODELS=
LLM_CRANE_COMPLEX_FALLBACK_MODELS=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=